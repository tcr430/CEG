{
  "name": "@ceg/testing",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "eval": "pnpm --dir ../.. --filter @ceg/validation build && pnpm --dir ../.. --filter @ceg/sequence-engine build && pnpm --dir ../.. --filter @ceg/testing build && node --experimental-strip-types tests/run-evals.ts",
    "lint": "eslint src tests --max-warnings=0",
    "test": "tsc --project tsconfig.json && node --experimental-strip-types tests/run-tests.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  }
}
