{
  "name": "@ceg/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@ceg/core": "workspace:*",
    "@ceg/validation": "workspace:*",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/pg": "^8.15.2"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "lint": "eslint src --max-warnings=0",
    "test": "tsc --project tsconfig.json && node --experimental-strip-types tests/run-tests.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  }
}
