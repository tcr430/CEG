# Compatibility mirror for AGENTS.md expectations.
# Keep this file aligned with .env.example.

# Template only. Copy these values into .env.local for actual local development.

# Core application
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Outbound Copilot

# Public app origin
# Set this explicitly in production so auth, billing, and metadata use your canonical domain.
# On Vercel preview deployments, the app can fall back to VERCEL_URL when this is omitted.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database and auth
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Reserved for trusted server-only billing, admin, and operational flows. It is not used by client-side auth.
# Never expose this via NEXT_PUBLIC_ variables or client-side imports.
SUPABASE_SERVICE_ROLE_KEY=

# Inbox provider configuration
# Required only when Gmail inbox connection and import are enabled.
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
# Optional if NEXT_PUBLIC_APP_URL already resolves to the public app origin.
GOOGLE_GMAIL_REDIRECT_URI=
# Base64-encoded 32-byte key for encrypting inbox OAuth credentials server-side.
INBOX_CREDENTIALS_ENCRYPTION_KEY=

# Provider configuration
# OpenAI remains the default provider. Anthropic can be enabled internally for evaluation or selective routing.
AI_DEFAULT_PROVIDER=openai
# Optional per-capability override: openai | anthropic
AI_RESEARCH_PROVIDER=
AI_SEQUENCE_PROVIDER=
AI_REPLY_PROVIDER=

OPENAI_API_KEY=
OPENAI_RESEARCH_MODEL=gpt-4.1-mini
OPENAI_SEQUENCE_MODEL=gpt-4.1-mini
OPENAI_REPLY_MODEL=gpt-4.1-mini

# Optional second-provider scaffold for internal evaluation and portability work.
ANTHROPIC_API_KEY=
ANTHROPIC_RESEARCH_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_SEQUENCE_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_REPLY_MODEL=claude-3-5-sonnet-latest

# Billing configuration
# Required only when Stripe billing flows are enabled.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_AGENCY_MONTHLY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Observability
LOG_LEVEL=info
SENTRY_DSN=

# Internal admin access
# Comma-separated allowlist of trusted emails.
INTERNAL_ADMIN_EMAILS=

# Development-only demo seeding
# Keep false in deployed environments.
DEMO_SEED_ENABLED=false

# Vercel system environment variables
# Vercel can provide these automatically at runtime. Do not set them manually unless you are simulating Vercel locally.
# VERCEL_URL=
# VERCEL_TARGET_ENV=
# VERCEL_PROJECT_PRODUCTION_URL=



