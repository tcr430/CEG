# Template only. Copy these values into .env.local for actual local development.

# Core application
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Outbound Copilot
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database and auth
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Provider configuration
OPENAI_API_KEY=
OPENAI_SEQUENCE_MODEL=gpt-4.1-mini
OPENAI_REPLY_MODEL=gpt-4.1-mini

# Billing placeholders
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Observability
LOG_LEVEL=info
SENTRY_DSN=
