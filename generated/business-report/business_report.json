  "workflow_steps": [
    "User lands on the marketing homepage and can navigate to sign-in or pricing.",
    "User signs in through a Supabase-backed magic-link flow.",
    "If the workspace is not set up, onboarding guides workspace confirmation, user type selection, sender profile/basic mode, first campaign, and first prospect.",
    "User creates or selects a campaign and manages prospects.",
    "User runs website research for a prospect, producing a structured company profile with evidence and confidence.",
    "User generates an outbound sequence using sender context, campaign context, prospect context, and prompt constraints.",
    "User reviews, regenerates, or manually edits generated sequence content.",
    "User can link generated outbound messages into a conversation thread and create a Gmail draft.",
    "Inbound replies enter by manual paste or Gmail import.",
    "The system stores the reply as a normalized message, classifies intent/objection/recommended action, and generates draft replies.",
    "User reviews or edits reply drafts and can push a selected draft into Gmail.",
    "The system updates metrics, usage/audit events, and outcome-aware learning signals."
  ],
  "architecture_summary": {
    "frontend": "Next.js App Router application in apps/web with public marketing pages and protected workspace pages.",
    "backend": "Server-side flows and route handlers live in apps/web/lib/server and app/api; business logic is intentionally kept outside React components.",
    "database": "Relational schema with workspace-scoped entities for users, workspaces, memberships, campaigns, prospects, research snapshots, sequences, threads/messages, reply analyses, draft replies, subscriptions, usage events, audit events, and inbox synchronization tables.",
    "validation": "Shared Zod contracts in packages/validation define entity and workflow shapes across the app.",
    "ai_layer": "Research, sequence generation, and reply intelligence use provider adapters behind internal contracts; OpenAI is default and Anthropic is scaffolded.",
    "async": "Slow operations persist explicit run states through a jobs contract but are not yet extracted into a dedicated queue/worker system.",
    "integrations": [
      "Supabase",
      "Stripe",
      "Gmail",
      "OpenAI",
      "Anthropic (internal scaffold)"
    ],
    "deployment_clues": [
      "Vercel-oriented deployment guide",
      "env-driven configuration",
      "Next.js 15 / React 19 app package"
    ]
  },
